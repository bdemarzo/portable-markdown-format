<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:PortableMarkdownFormat.Viewer.ViewModels"
        xmlns:md="clr-namespace:Markdown.Avalonia;assembly=Markdown.Avalonia"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        d:DesignWidth="1200"
        d:DesignHeight="760"
        x:Class="PortableMarkdownFormat.Viewer.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Width="1200"
        Height="760"
        MinWidth="960"
        MinHeight="620"
        Icon="/Assets/avalonia-logo.ico"
        Title="Portable Markdown Format Viewer">

    <Design.DataContext>
        <vm:MainWindowViewModel />
    </Design.DataContext>

    <Grid Margin="16"
          RowDefinitions="Auto,Auto,*,Auto"
          RowSpacing="16">
        <StackPanel Orientation="Horizontal"
                    Spacing="12">
            <Button Click="OpenPackageButton_OnClick"
                    Content="Open PMF..." />
            <TextBlock VerticalAlignment="Center"
                       Text="{Binding PackagePath}"
                       TextTrimming="CharacterEllipsis" />
        </StackPanel>

        <Border Grid.Row="1"
                Padding="16"
                BorderBrush="Gray"
                BorderThickness="1"
                CornerRadius="8">
            <TextBlock Text="{Binding PackageSummary}" />
        </Border>

        <Grid Grid.Row="2"
              ColumnDefinitions="320,*"
              ColumnSpacing="16">
            <Border Padding="16"
                    BorderBrush="Gray"
                    BorderThickness="1"
                    CornerRadius="8">
                <Grid RowDefinitions="Auto,*"
                      RowSpacing="12">
                    <TextBlock FontSize="16"
                               FontWeight="SemiBold"
                               Text="Packaged files" />
                    <ListBox Grid.Row="1"
                             ItemsSource="{Binding Files}"
                             SelectedItem="{Binding SelectedFile}">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Spacing="2">
                                    <TextBlock Text="{Binding RelativePath}"
                                               TextWrapping="Wrap" />
                                    <TextBlock FontSize="12"
                                               Opacity="0.75"
                                               Text="{Binding Subtitle}" />
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>

            <Border Grid.Column="1"
                    Padding="16"
                    BorderBrush="Gray"
                    BorderThickness="1"
                    CornerRadius="8">
                <Grid RowDefinitions="Auto,*"
                      RowSpacing="12">
                    <TextBlock FontSize="16"
                               FontWeight="SemiBold"
                               Text="{Binding SelectedPathHeader}" />
                    <md:MarkdownScrollViewer Grid.Row="1"
                                             Markdown="{Binding SelectedMarkdown}" />
                </Grid>
            </Border>
        </Grid>

        <TextBlock Grid.Row="3"
                   Text="{Binding StatusMessage}"
                   TextWrapping="Wrap" />
    </Grid>
</Window>
